-- ФУНКЦИЯ ЖИРНЫХ СЛАЙДЕРОВ (4px)
local function addSlider(name, y, max, default, globalVar)
    local sliderId = name
    local lab = Instance.new("TextLabel", content)
    lab.Size = UDim2.new(1, -30, 0, 20)
    lab.Position = UDim2.new(0, 15, 0, y)
    lab.Text = name..": "..default
    lab.TextColor3 = Color3.new(1,1,1)
    lab.TextSize = 14
    lab.Font = Enum.Font.GothamMedium
    lab.BackgroundTransparency = 1
    lab.TextXAlignment = Enum.TextXAlignment.Left

    local sliderBg = Instance.new("TextButton", content)
    sliderBg.Size = UDim2.new(0.9, 0, 0, 4) -- Жирненько
    sliderBg.Position = UDim2.new(0.05, 0, 0, y + 25)
    sliderBg.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    sliderBg.Text = ""
    sliderBg.AutoButtonColor = false
    Instance.new("UICorner", sliderBg)

    local fill = Instance.new("Frame", sliderBg)
    fill.Size = UDim2.new(default/max, 0, 1, 0)
    fill.BackgroundColor3 = Color3.new(1,1,1)
    fill.BorderSizePixel = 0
    Instance.new("UICorner", fill)

    local gradient = Instance.new("UIGradient", fill)
    gradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
        ColorSequenceKeypoint.new(0.2, Color3.fromRGB(255, 255, 0)),
        ColorSequenceKeypoint.new(0.4, Color3.fromRGB(0, 255, 0)),
        ColorSequenceKeypoint.new(0.6, Color3.fromRGB(0, 255, 255)),
        ColorSequenceKeypoint.new(0.8, Color3.fromRGB(0, 0, 255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 255))
    })
    TweenService:Create(gradient, TweenInfo.new(3, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, -1), {Offset = Vector2.new(-1, 0)}):Play()

    local dot = Instance.new("Frame", fill)
    dot.Size = UDim2.new(0, 12, 0, 12)
    dot.Position = UDim2.new(1, -6, 0.5, -6)
    dot.BackgroundColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", dot)

    local function update(input)
        local mousePos = input.Position.X
        local barPos = sliderBg.AbsolutePosition.X
        local barSize = sliderBg.AbsoluteSize.X
        local percent = math.clamp((mousePos - barPos) / barSize, 0, 1)
        fill.Size = UDim2.new(percent, 0, 1, 0)
        local val = math.floor(percent * max)
        lab.Text = name..": "..val
        _G[globalVar] = val
    end

    sliderBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            draggingSlider = sliderId
            update(input)
        end
    end)
    UIS.InputChanged:Connect(function(input)
        if draggingSlider == sliderId and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            update(input)
        end
    end)
    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            draggingSlider = nil
        end
    end)
    RS.RenderStepped:Connect(function() dot.BackgroundColor3 = Color3.fromHSV(tick() % 5 / 5, 1, 1) end)
end

