-- СИСТЕМА ИЗОЛИРОВАННЫХ СЛАЙДЕРОВ
local draggingSlider = nil -- Переменная хранит, какой именно слайдер сейчас тянем

local function addSlider(name, y, max, default, prop)
    local sliderId = name -- Уникальный ID слайдера
    
    local lab = Instance.new("TextLabel", content)
    lab.Size = UDim2.new(1, 0, 0, 15)
    lab.Position = UDim2.new(0, 0, 0, y)
    lab.Text = name..": "..default
    lab.TextColor3 = Color3.new(1,1,1)
    lab.TextSize = 11
    lab.BackgroundTransparency = 1

    local sliderBg = Instance.new("TextButton", content)
    sliderBg.Size = UDim2.new(0.8, 0, 0, 4)
    sliderBg.Position = UDim2.new(0.1, 0, 0, y + 18)
    sliderBg.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    sliderBg.Text = ""
    sliderBg.AutoButtonColor = false
    Instance.new("UICorner", sliderBg)

    local fill = Instance.new("Frame", sliderBg)
    fill.Size = UDim2.new(default/max, 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(0, 170, 255)
    Instance.new("UICorner", fill)

    local function update(input)
        local mousePos = input.Position.X
        local barPos = sliderBg.AbsolutePosition.X
        local barSize = sliderBg.AbsoluteSize.X
        local percent = math.clamp((mousePos - barPos) / barSize, 0, 1)
        
        fill.Size = UDim2.new(percent, 0, 1, 0)
        local val = math.floor(percent * max)
        lab.Text = name..": "..val
        
        if player.Character and player.Character:FindFirstChild("Humanoid") then
            player.Character.Humanoid[prop] = val
        end
    end

    sliderBg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            draggingSlider = sliderId -- Захватываем ID
            main.Draggable = false
            update(input)
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if draggingSlider == sliderId and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            update(input)
        end
    end)

    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if draggingSlider == sliderId then
                draggingSlider = nil -- Освобождаем
                main.Draggable = true
            end
        end
    end)
end

-- ВЫЗОВ СЛАЙДЕРОВ
