--- ЛОГИКА ФУНКЦИЙ ---

-- Скорость
sBar.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then
        draggingSlider = true
        while draggingSlider do
            local mPos = UserInputService:GetMouseLocation().X
            local relPos = mPos - sBar.AbsolutePosition.X
            local per = math.clamp(relPos / sBar.AbsoluteSize.X, 0, 1)
            sFill.Size = UDim2.new(per, 0, 1, 0)
            local val = math.floor(16 + (484 * per))
            sTitle.Text = "Speed: "..val
            if player.Character:FindFirstChild("Humanoid") then player.Character.Humanoid.WalkSpeed = val end
            task.wait()
        end
    end
end)

-- Прыжок
jBar.InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then
        draggingSlider = true
        while draggingSlider do
            local mPos = UserInputService:GetMouseLocation().X
            local relPos = mPos - jBar.AbsolutePosition.X
            local per = math.clamp(relPos / jBar.AbsoluteSize.X, 0, 1)
            jFill.Size = UDim2.new(per, 0, 1, 0)
            local val = math.floor(50 + (450 * per))
            jTitle.Text = "Jump: "..val
            if player.Character:FindFirstChild("Humanoid") then 
                player.Character.Humanoid.JumpPower = val 
                player.Character.Humanoid.UseJumpPower = true
            end
            task.wait()
        end
    end
end)

UserInputService.InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then
        draggingSlider = false
    end
end)

-- Бесконечный прыжок
local infJump = false
toggleBtn.MouseButton1Click:Connect(function()
    infJump = not infJump
    toggleBtn.BackgroundColor3 = infJump and Color3.fromRGB(50, 180, 50) or Color3.fromRGB(180, 50, 50)
    toggleBtn.Text = "Infinite Jump: "..(infJump and "ON" or "OFF")
end)

UserInputService.JumpRequest:Connect(function()
    if infJump and player.Character then
        player.Character:FindFirstChildOfClass("Humanoid"):ChangeState("Jumping")
    end
end)

-- ЛОГИКА СВЕРНУТЬ (Твой кайф)
local isMin = false
minBtn.MouseButton1Click:Connect(function()
    isMin = not isMin
    mainFrame:TweenSize(isMin and UDim2.new(0, 260, 0, 40) or UDim2.new(0, 260, 0, 240), "Out", "Quad", 0.4, true)
    minBtn.Text = isMin and "+" or "-"
    -- Скрываем элементы напрямую
    sTitle.Visible = not isMin
    sBar.Visible = not isMin
    jTitle.Visible = not isMin
    jBar.Visible = not isMin
    toggleBtn.Visible = not isMin
end)

closeBtn.MouseButton1Click:Connect(function() screenGui:Destroy() end)

