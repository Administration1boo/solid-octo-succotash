--- ЛОГИКА ФУНКЦИЙ ---

-- Скорость
sBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        local connection
        connection = UserInputService.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                local pos = math.clamp((input.Position.X - sBar.AbsolutePosition.X) / sBar.AbsoluteSize.X, 0, 1)
                sFill.Size = UDim2.new(pos, 0, 1, 0)
                local speed = math.floor(pos * 500)
                sTitle.Text = "Скорость: "..speed
                локальный_игрок.Character.Humanoid.WalkSpeed = speed
            end
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                connection:Disconnect()
            end
        end)
    end
end)

-- Прыжок
jBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        local connection
        connection = UserInputService.InputChanged:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                local pos = math.clamp((input.Position.X - jBar.AbsolutePosition.X) / jBar.AbsoluteSize.X, 0, 1)
                jFill.Size = UDim2.new(pos, 0, 1, 0)
                local jump = math.floor(pos * 500)
                jTitle.Text = "Прыжок: "..jump
                локальный_игрок.Character.Humanoid.JumpPower = jump
            end
        end)
        UserInputService.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                connection:Disconnect()
            end
        end)
    end
end)

-- Бесконечный прыжок
local infJump = false
toggleBtn.MouseButton1Click:Connect(function()
    infJump = not infJump
    toggleBtn.Text = "Бесконечный прыжок: "..(infJump and "ВКЛ" or "ВЫКЛ")
    toggleBtn.BackgroundColor3 = infJump and Color3.fromRGB(50, 180, 50) or Color3.fromRGB(180, 50, 50)
end)

UserInputService.JumpRequest:Connect(function()
    if infJump then
        локальный_игрок.Character:FindFirstChildOfClass("Humanoid"):ChangeState("Jumping")
    end
end)
