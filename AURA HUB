-- SLIDERS

local function slider(name,min,max,y)

local dragging=false

local label=Instance.new("TextLabel",sliders)
label.Size=UDim2.new(.8,0,0,20)
label.Position=UDim2.new(.1,0,0,y)
label.BackgroundTransparency=1
label.Text=name..": "..min
label.TextScaled=true
label.TextColor3=Color3.fromRGB(220,0,255)

local bar=Instance.new("Frame",sliders)
bar.Size=UDim2.new(.8,0,0,10)
bar.Position=UDim2.new(.1,0,0,y+22)
bar.BackgroundColor3=Color3.fromRGB(80,0,120)

local fill=Instance.new("Frame",bar)
fill.Size=UDim2.new(0,0,1,0)
fill.BackgroundColor3=Color3.fromRGB(220,0,255)

local function update(x)

local pos=(x-bar.AbsolutePosition.X)/bar.AbsoluteSize.X
pos=math.clamp(pos,0,1)

fill.Size=UDim2.new(pos,0,1,0)

local value=math.floor((max-min)*pos+min)

label.Text=name..": "..value

if name=="Speed" then speedValue=value end
if name=="Jump" then jumpValue=value end

end

bar.InputBegan:Connect(function(input)

if input.UserInputType==Enum.UserInputType.MouseButton1
or input.UserInputType==Enum.UserInputType.Touch then

dragging=true
update(input.Position.X)

end

end)

UIS.InputChanged:Connect(function(input)

if dragging and (
input.UserInputType==Enum.UserInputType.MouseMovement
or input.UserInputType==Enum.UserInputType.Touch) then

update(input.Position.X)

end

end)

UIS.InputEnded:Connect(function(input)

if input.UserInputType==Enum.UserInputType.MouseButton1
or input.UserInputType==Enum.UserInputType.Touch then
dragging=false
end

end)

end

slider("Speed",16,200,20)
slider("Jump",50,200,80)

